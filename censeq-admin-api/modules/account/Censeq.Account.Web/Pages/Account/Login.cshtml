@section scripts
{
	<script src="~/libs/starshine/js/login.js" asp-append-version="true"></script>
	<script>
		(function () {
			var lockPreset = @(Model.IsEnterpriseTenantPresetFromLink ? "true" : "false");
			var scopeInput = document.getElementById('loginScopeInput');
			var enterpriseRow = document.querySelector('.enterprise-tenant-field');
			var platformHint = document.querySelector('.platform-hint');
			var tabPlatform = document.getElementById('tab-platform');
			var tabEnterprise = document.getElementById('tab-enterprise');
			function setTab(scope) {
				if (lockPreset && scope === 'platform') {
					return;
				}
				if (scopeInput) {
					scopeInput.value = scope;
				}
				if (scope === 'enterprise') {
					if (enterpriseRow) enterpriseRow.style.display = 'block';
					if (platformHint) platformHint.style.display = 'none';
					tabEnterprise && tabEnterprise.classList.add('active');
					tabPlatform && tabPlatform.classList.remove('active');
				} else {
					if (enterpriseRow) enterpriseRow.style.display = 'none';
					if (platformHint) platformHint.style.display = 'block';
					tabPlatform && tabPlatform.classList.add('active');
					tabEnterprise && tabEnterprise.classList.remove('active');
				}
			}
			document.querySelectorAll('#loginTenantTabs button[data-tab-scope]').forEach(function (btn) {
				btn.addEventListener('click', function (e) {
					e.preventDefault();
					setTab(btn.getAttribute('data-tab-scope'));
				});
			});
			if (@(Model.AutoSelectEnterpriseTab ? "true" : "false")) {
				setTab('enterprise');
			} else {
				setTab('platform');
			}
		})();
	</script>
}
