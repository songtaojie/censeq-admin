<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="..\..\..\common.props" />

	<PropertyGroup>
		<AssemblyName>Censeq.FeatureManagement.EntityFrameworkCore</AssemblyName>
		<PackageId>Censeq.FeatureManagement.EntityFrameworkCore</PackageId>
		<Nullable>enable</Nullable>
		<RootNamespace>Censeq.FeatureManagement</RootNamespace>
		<GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
	</PropertyGroup>

	<ItemGroup>
		<EmbeddedResource Include="Localization\Resources\*.json" />
		<Content Remove="Localization\Resources\*.json" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\..\framework\Censeq.Framework.EntityFrameworkCore\Censeq.Framework.EntityFrameworkCore.csproj" />
	  <ProjectReference Include="..\Censeq.FeatureManagement.Domain\Censeq.FeatureManagement.Domain.csproj" />
	</ItemGroup>

</Project>
