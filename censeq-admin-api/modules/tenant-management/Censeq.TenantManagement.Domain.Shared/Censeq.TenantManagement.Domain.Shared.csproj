<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="..\..\..\common.props" />

	<PropertyGroup>
		<AssemblyName>Censeq.TenantManagement.Domain.Shared</AssemblyName>
		<PackageId>Censeq.TenantManagement.Domain.Shared</PackageId>
		<Nullable>enable</Nullable>
		<RootNamespace>Censeq.TenantManagement</RootNamespace>
		<GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
	</PropertyGroup>

	<ItemGroup>
		<EmbeddedResource Include="Localization\Resources\*.json" />
		<Content Remove="Localization\Resources\*.json" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Volo.Abp.Auditing.Contracts" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Localization" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Features" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Validation" Version="$(AbpVersion)" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="$(MicrosoftExtensionsFileProvidersEmbeddedVersion)" />
	</ItemGroup>

</Project>
