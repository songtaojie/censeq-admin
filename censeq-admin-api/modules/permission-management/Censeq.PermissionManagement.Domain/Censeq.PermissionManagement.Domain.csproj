<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="..\..\..\common.props" />

	<PropertyGroup>
		<AssemblyName>Censeq.PermissionManagement.Domain</AssemblyName>
		<PackageId>Censeq.PermissionManagement.Domain</PackageId>
		<Nullable>enable</Nullable>
		<RootNamespace>Censeq.PermissionManagement</RootNamespace>
		<GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Volo.Abp" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Ddd.Domain" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Guids" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Authorization" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Caching" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.DistributedLocking" Version="$(AbpVersion)" />
		<PackageReference Include="Volo.Abp.Json" Version="$(AbpVersion)" />
		<PackageReference Include="Polly" Version="$(PollyVersion)" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\Censeq.PermissionManagement.Domain.Shared\Censeq.PermissionManagement.Domain.Shared.csproj" />
	</ItemGroup>

</Project>
