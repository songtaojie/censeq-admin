<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="..\..\..\common.props" />

	<PropertyGroup>
		<AssemblyName>Censeq.PermissionManagement.Domain.Shared</AssemblyName>
		<PackageId>Censeq.PermissionManagement.Domain.Shared</PackageId>
		<Nullable>enable</Nullable>
		<RootNamespace>Censeq.PermissionManagement</RootNamespace>
		<GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
	</PropertyGroup>

	<ItemGroup>
		<EmbeddedResource Include="Localization\Resources\*.json" />
		<Content Remove="Localization\Resources\*.json" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Volo.Abp.Localization" />
		<PackageReference Include="Volo.Abp.Validation" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" />
	</ItemGroup>

</Project>
