@if (ViewContext.ModelState.IsValid == false)
{
    <div id="errorToast" class="toast align-items-center text-bg-danger border-0 start-50 position-absolute translate-middle-x" role="alert" aria-live="assertive" aria-atomic="true"
         data-bs-autohide="true" data-bs-delay="3000" style="top:1.2rem;">
        <div class="d-flex">
            <div asp-validation-summary="All" class="toast-body"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
}