@page
@model Starshine.Admin.Web.Pages.Account.Password.PasswordResetLinkSentModel
@using Microsoft.AspNetCore.Mvc.Localization
@using Starshine.Admin.Localization
@using Starshine.Admin.Web.Pages.Account.Password
@inject IHtmlLocalizer<AdminResource> L
<div class="card mt-3 shadow-sm rounded">
    <div class="card-body p-5">
        <h4>@L["ForgotPassword"]</h4>
        <form method="post" class="mt-4">
            <p>@L["PasswordResetMailSentMessage"]</p>
            <a abp-button="Primary" asp-page="./Login"
                asp-all-route-data="@(new Dictionary<string, string> { { "returnUrl", Model.ReturnUrl }, { "returnUrlHash", Model.ReturnUrlHash } })">&larr;
                @L["BackToLogin"]</a>
        </form>
    </div>
</div>
