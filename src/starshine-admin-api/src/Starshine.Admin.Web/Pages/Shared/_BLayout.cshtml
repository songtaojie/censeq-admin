@{
    bool isLoginPage = ViewBag.IsLoginPage == true;
}
<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - 海·星の博客</title>
    <partial name="_Styles" />
    @await RenderSectionAsync("styles", required: false)
</head>
<body>
    <div class="container-fluid w-100 h-100 m-0 p-0 position-relative">
        @RenderBody()
    </div>
    <partial name="_Scripts" />
    @RenderSection("scripts", required: false)
</body>
</html>
